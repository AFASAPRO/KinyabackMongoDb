# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas (replace with your connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kinyabot?retryWrites=true&w=majority

# JWT (change in production!)
JWT_SECRET=kinyabot_super_secret_jwt_key_change_this_now_2024
ADMIN_SECRET=admin_jwt_secret_different_from_user_secret

# AI APIs
LLM_API_URL=https://backend.buildpicoapps.com/aero/run/llm-api?pk=YOUR_KEY
IMAGE_API_URL=https://backend.buildpicoapps.com/aero/run/image-generation-api?pk=YOUR_KEY

# SMTP Email (Gmail example - use App Password for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="KinyaBot AI <your@gmail.com>"

# Admin credentials (change these!)
ADMIN_EMAIL=admin@kinyabot.ai
ADMIN_PASSWORD=KinyaBot@Admin2024

# Admin invite code for registering additional admins
ADMIN_INVITE_CODE=KinyaBot-Admin-2024

# Firebase (for Google login)
FIREBASE_PROJECT_ID=your-firebase-project-id
